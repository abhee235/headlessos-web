---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title="Blog · HeadlessOS"
  description="News, deep-dives, and updates from the HeadlessOS team."
>
  <section class="relative bg-mesh py-24">
    <div class="mx-auto max-w-4xl px-6">
      <p class="chip">Blog</p>
      <h1 class="mt-5 text-5xl font-bold tracking-tight">
        Updates from the <span class="gradient-text">HeadlessOS</span> team.
      </h1>
      <p class="mt-4 text-lg text-[var(--color-fg-muted)] max-w-2xl">
        Release notes, technical deep-dives, and the occasional rant about
        terminal output formats.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-4xl px-6">
      {
        posts.length === 0 ? (
          <p class="text-[var(--color-fg-muted)] text-center py-20">
            No posts yet. Check back soon.
          </p>
        ) : (
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  class="block rounded-xl glass p-6 hover:border-[rgba(0,212,255,0.3)] transition-colors"
                >
                  <div class="flex items-center gap-3 text-xs text-[var(--color-fg-subtle)]">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatter.format(post.data.pubDate)}
                    </time>
                    <span>·</span>
                    <span>{post.data.author}</span>
                  </div>
                  <h2 class="mt-2 text-2xl font-semibold">{post.data.title}</h2>
                  <p class="mt-2 text-[var(--color-fg-muted)]">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                      {post.data.tags.map((t) => (
                        <span class="text-xs px-2 py-0.5 rounded-full bg-[rgba(255,255,255,0.05)] text-[var(--color-fg-muted)]">
                          #{t}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>
