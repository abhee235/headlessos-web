---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { renderRingTick, angleStudy } from "@/lib/icons-v3";
---

<BaseLayout
  title="Ring-Tick H — angle study · HeadlessOS"
  description="Angle study for the chosen Ring-Tick H icon."
  noindex={true}
>
  <section class="px-6 py-20 md:px-10 max-w-7xl mx-auto">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-text-tertiary)]">Icon · Ring-Tick H</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mt-2 gradient-text">Angle study</h1>
      <p class="text-[var(--color-text-secondary)] max-w-2xl mt-3">
        Same mark, 16 dot positions around the clock. 0° = top, clockwise. Click any tile to copy its angle.
      </p>
    </header>

    <!-- INTERACTIVE PICKER -->
    <div class="glass rounded-2xl p-6 mb-12 flex flex-col md:flex-row items-center gap-8">
      <div class="w-40 h-40 shrink-0" id="preview-large"></div>
      <div class="flex-1 w-full">
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-semibold text-[var(--color-text-primary)]">Dot angle</label>
          <span class="font-mono text-[var(--color-brand-400)]" id="angle-val">0°</span>
        </div>
        <input
          id="angle-slider"
          type="range"
          min="0"
          max="359"
          step="1"
          value="0"
          class="w-full accent-[var(--color-brand-500)]"
        />
        <div class="flex items-center justify-between mt-6 mb-2">
          <label class="text-sm font-semibold text-[var(--color-text-primary)]">Arc span</label>
          <span class="font-mono text-[var(--color-brand-400)]" id="arc-val">270°</span>
        </div>
        <input
          id="arc-slider"
          type="range"
          min="60"
          max="340"
          step="5"
          value="270"
          class="w-full accent-[var(--color-brand-500)]"
        />
        <div class="flex items-center justify-between mt-6 mb-2">
          <label class="text-sm font-semibold text-[var(--color-text-primary)]">Dot size</label>
          <span class="font-mono text-[var(--color-brand-400)]" id="dot-val">2.2</span>
        </div>
        <input
          id="dot-slider"
          type="range"
          min="1.4"
          max="4"
          step="0.1"
          value="2.2"
          class="w-full accent-[var(--color-brand-500)]"
        />
        <div class="mt-6 flex flex-wrap gap-2 items-center">
          <span class="text-xs uppercase tracking-wider text-[var(--color-text-tertiary)] mr-2">Preview at</span>
          <div class="flex items-end gap-3">
            <div class="size-p" data-px="24"></div>
            <div class="size-p" data-px="32"></div>
            <div class="size-p" data-px="48"></div>
            <div class="size-p" data-px="64"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 16-ANGLE GRID -->
    <h2 class="text-xs uppercase tracking-[0.3em] text-[var(--color-brand-400)] mb-4">16 positions</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {angleStudy.map((p) => (
        <button
          class="angle-card"
          data-angle={p.angle}
          data-copy={`${p.angle}°`}
        >
          <div class="icon-stage">
            <div class="icon-96" set:html={renderRingTick({ angle: p.angle })}></div>
          </div>
          <div class="mt-3 flex items-baseline justify-between">
            <span class="font-mono text-sm text-[var(--color-brand-400)]">{p.angle}°</span>
            <span class="text-xs text-[var(--color-text-tertiary)]">{p.label.split("—")[1]?.trim() ?? ""}</span>
          </div>
        </button>
      ))}
    </div>

    <!-- DOCK PREVIEW -->
    <div class="mt-12">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-brand-400)] mb-3">Dock preview · 56px</p>
      <div class="dock">
        {angleStudy.map((p) => (
          <div class="dock-slot" title={`${p.angle}°`} set:html={renderRingTick({ angle: p.angle })}></div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .icon-stage {
    border-radius: 0.75rem;
    padding: 1rem;
    display: grid;
    place-items: center;
    background: #0d0d14;
    min-height: 140px;
  }
  .icon-96 { width: 96px; height: 96px; display: grid; place-items: center; }
  .angle-card {
    padding: 0.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.01);
    transition: all 0.15s ease;
    cursor: pointer;
    text-align: left;
  }
  .angle-card:hover {
    border-color: var(--color-brand-500);
    transform: translateY(-2px);
  }
  .dock {
    display: flex;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    border-radius: 1.25rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    overflow-x: auto;
    align-items: center;
  }
  .dock-slot {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
  }
  .size-p {
    padding: 0.35rem;
    background: #0d0d14;
    border-radius: 0.35rem;
    display: grid;
    place-items: center;
  }
  .size-p[data-px="24"] { width: 32px; height: 32px; }
  .size-p[data-px="24"] > * { width: 24px; height: 24px; }
  .size-p[data-px="32"] { width: 40px; height: 40px; }
  .size-p[data-px="32"] > * { width: 32px; height: 32px; }
  .size-p[data-px="48"] { width: 56px; height: 56px; }
  .size-p[data-px="48"] > * { width: 48px; height: 48px; }
  .size-p[data-px="64"] { width: 72px; height: 72px; }
  .size-p[data-px="64"] > * { width: 64px; height: 64px; }
</style>

<script>
  // Simplified inline renderer that mirrors renderRingTick() for live preview.
  function polar(cx: number, cy: number, r: number, a: number): [number, number] {
    const rad = ((a - 90) * Math.PI) / 180;
    return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];
  }
  function render(angle: number, arcSpan: number, dotSize: number): string {
    const cx = 32, cy = 32, r = 18, stroke = 2.5;
    const arcStart = angle + (360 - arcSpan);
    const [x1, y1] = polar(cx, cy, r, arcStart);
    const [x2, y2] = polar(cx, cy, r, angle);
    const largeArc = arcSpan > 180 ? 1 : 0;
    const path = `M ${x1.toFixed(2)} ${y1.toFixed(2)} A ${r} ${r} 0 ${largeArc} 1 ${x2.toFixed(2)} ${y2.toFixed(2)}`;
    const [dx, dy] = polar(cx, cy, r, angle);
    return `
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <defs>
        <linearGradient id="rt-b" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#00d4ff"/><stop offset="1" stop-color="#7c3aed"/>
        </linearGradient>
        <linearGradient id="rt-s" x1="0" y1="0" x2="0" y2="32" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#fff" stop-opacity="0.3"/>
          <stop offset="1" stop-color="#fff" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <rect width="64" height="64" rx="14" fill="url(#rt-b)"/>
      <rect width="64" height="32" rx="14" fill="url(#rt-s)"/>
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#fff" stroke-opacity="0.15" stroke-width="${stroke}"/>
      <path d="${path}" fill="none" stroke="#fff" stroke-width="${stroke}" stroke-linecap="round"/>
      <circle cx="${dx.toFixed(2)}" cy="${dy.toFixed(2)}" r="${dotSize}" fill="#fff"/>
      <g fill="#fff">
        <rect x="24" y="23" width="3" height="18" rx="1"/>
        <rect x="37" y="23" width="3" height="18" rx="1"/>
        <rect x="24" y="30.5" width="16" height="3" rx="1"/>
      </g>
    </svg>`;
  }

  const $ = <T extends HTMLElement>(s: string) => document.querySelector(s) as T;
  const angleEl = $<HTMLInputElement>("#angle-slider");
  const arcEl = $<HTMLInputElement>("#arc-slider");
  const dotEl = $<HTMLInputElement>("#dot-slider");
  const angleVal = $("#angle-val");
  const arcVal = $("#arc-val");
  const dotVal = $("#dot-val");
  const preview = $("#preview-large");
  const sizes = document.querySelectorAll<HTMLElement>(".size-p");

  function update() {
    const a = +angleEl.value, s = +arcEl.value, d = +dotEl.value;
    const svg = render(a, s, d);
    angleVal.textContent = `${a}°`;
    arcVal.textContent = `${s}°`;
    dotVal.textContent = d.toFixed(1);
    preview.innerHTML = svg;
    sizes.forEach((el) => (el.innerHTML = svg));
  }
  [angleEl, arcEl, dotEl].forEach((el) => el.addEventListener("input", update));
  update();

  // Click an angle card to load it into the picker
  document.querySelectorAll<HTMLButtonElement>(".angle-card").forEach((card) => {
    card.addEventListener("click", () => {
      angleEl.value = card.dataset.angle || "0";
      update();
      navigator.clipboard?.writeText(card.dataset.copy || "").catch(() => {});
      card.style.borderColor = "var(--color-brand-500)";
      card.style.boxShadow = "0 0 0 2px rgba(0,212,255,0.3)";
      setTimeout(() => {
        card.style.borderColor = "";
        card.style.boxShadow = "";
      }, 500);
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
</script>
