---
// Hero section — top of the landing page
---

<section class="relative overflow-hidden bg-mesh">
  <div class="absolute inset-0 bg-grid pointer-events-none"></div>

  <!-- floating accent blobs -->
  <div
    class="absolute -top-40 -left-32 h-96 w-96 rounded-full bg-[var(--color-brand-500)] opacity-20 blur-3xl float-slow pointer-events-none"
  >
  </div>
  <div
    class="absolute -top-20 right-0 h-96 w-96 rounded-full bg-[var(--color-accent-500)] opacity-15 blur-3xl float-slow pointer-events-none"
    style="animation-delay:-3s"
  >
  </div>

  <div
    class="relative mx-auto max-w-6xl px-6 pt-24 pb-32 text-center sm:pt-28"
  >
    <a
      href="https://github.com/abhee235/headlessos"
      target="_blank"
      rel="noopener"
      class="chip mx-auto"
    >
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-brand-400)] animate-pulse"></span>
      Open source · Now in active development
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m9 18 6-6-6-6" />
      </svg>
    </a>

    <h1
      class="mt-6 text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-[1.05]"
    >
      Manage your VPS
      <br />
      <span class="gradient-text">like a desktop.</span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg sm:text-xl text-[var(--color-fg-muted)] leading-relaxed"
    >
      HeadlessOS turns any headless Linux server into a familiar desktop
      experience — file explorer, Docker dashboard, system monitor, and more.
      <br class="hidden sm:block" />
      <span class="text-[var(--color-fg)]"
        >Nothing installed on your server. Just SSH.</span
      >
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="/docs/getting-started" class="btn btn-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="https://github.com/abhee235/headlessos"
        target="_blank"
        rel="noopener"
        class="btn btn-secondary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-1-.02-1.96-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.9 10.9 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.74.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
          />
        </svg>
        Star on GitHub
      </a>
    </div>

    <p class="mt-5 text-sm text-[var(--color-fg-subtle)]">
      Free · Self-hosted · No telemetry · Works with any Linux server
    </p>

    <!-- Hero product preview frame -->
    <div class="relative mt-20">
      <!-- glow under window -->
      <div
        class="absolute -inset-x-20 -top-12 h-72 bg-[var(--color-brand-500)] opacity-15 blur-3xl pointer-events-none"
      >
      </div>

      <div
        class="relative mx-auto max-w-5xl rounded-2xl glass overflow-hidden shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)]"
      >
        <!-- macOS-style title bar -->
        <div
          class="flex items-center gap-1.5 px-4 py-3 border-b border-[var(--color-border)] bg-[rgba(255,255,255,0.02)]"
        >
          <span class="h-3 w-3 rounded-full bg-[#FF5F57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#FEBC2E]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28C841]"></span>
          <div
            class="ml-4 flex-1 max-w-md mx-auto rounded-md bg-[rgba(255,255,255,0.04)] py-1 px-3 text-xs text-[var(--color-fg-subtle)] text-center"
          >
            headlessos · my-vps@123.45.67.89
          </div>
        </div>

        <!-- App preview placeholder -->
        <div class="aspect-[16/10] bg-[var(--color-bg)] relative overflow-hidden">
          <!-- Sidebar -->
          <div
            class="absolute left-0 top-0 bottom-0 w-48 border-r border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-3 space-y-1.5"
          >
            {
              ["Dashboard", "Files", "Docker", "Processes", "Terminal", "Server Admin"].map(
                (item, i) => (
                  <div
                    class={`flex items-center gap-2 rounded px-2.5 py-1.5 text-xs ${i === 0 ? "bg-[rgba(0,212,255,0.1)] text-[var(--color-brand-300)]" : "text-[var(--color-fg-muted)]"}`}
                  >
                    <span class="h-1.5 w-1.5 rounded-full bg-current opacity-60" />
                    {item}
                  </div>
                )
              )
            }
          </div>

          <!-- Main content area: dashboard cards -->
          <div class="absolute left-48 top-0 right-0 bottom-0 p-5 grid grid-cols-3 gap-3">
            {
              [
                { label: "CPU", value: "23%", color: "var(--color-brand-400)" },
                { label: "Memory", value: "1.4 / 4 GB", color: "#a78bfa" },
                { label: "Disk", value: "42 / 80 GB", color: "#34d399" },
                { label: "Network", value: "2.1 MB/s", color: "#fbbf24" },
                { label: "Uptime", value: "12d 4h", color: "#f472b6" },
                { label: "Containers", value: "7 running", color: "var(--color-brand-400)" },
              ].map((c) => (
                <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-3">
                  <div class="text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                    {c.label}
                  </div>
                  <div class="mt-1 text-sm font-semibold" style={`color:${c.color}`}>
                    {c.value}
                  </div>
                  <div class="mt-2 h-1 w-full rounded-full bg-[rgba(255,255,255,0.05)] overflow-hidden">
                    <div
                      class="h-full rounded-full"
                      style={`width:${30 + Math.random() * 50}%; background:${c.color}; opacity:0.7`}
                    />
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Subtle scanline overlay -->
          <div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-transparent via-transparent to-[var(--color-bg)]/40"></div>
        </div>
      </div>
    </div>
  </div>
</section>
