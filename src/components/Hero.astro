---
// Hero section — top of the landing page
import HeroCarousel from "@/components/HeroCarousel.astro";

const socialProof = [
  "MIT licensed",
  "No agents installed",
  "Works with any Linux VPS",
  "Offline-capable desktop app",
];
---

<section class="relative overflow-hidden bg-mesh">
  <div class="absolute inset-0 bg-grid pointer-events-none"></div>

  <!-- floating accent blobs -->
  <div
    class="absolute -top-40 -left-32 h-96 w-96 rounded-full bg-[var(--color-brand-500)] opacity-20 blur-3xl float-slow pointer-events-none"
  >
  </div>
  <div
    class="absolute -top-20 right-0 h-96 w-96 rounded-full bg-[var(--color-accent-500)] opacity-15 blur-3xl float-slow pointer-events-none"
    style="animation-delay:-3s"
  >
  </div>

  <div
    class="relative mx-auto max-w-6xl px-6 pt-24 pb-28 text-center sm:pt-28"
  >
    <a
      href="https://github.com/abhee235/headlessos"
      target="_blank"
      rel="noopener"
      class="chip mx-auto"
    >
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-brand-400)] animate-pulse"></span>
      Now in public beta · Free &amp; open source
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m9 18 6-6-6-6" />
      </svg>
    </a>

    <h1
      class="mt-6 text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-[1.02]"
    >
      Stop SSH-ing into servers<br />
      <span class="gradient-text">like it's 2009.</span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg sm:text-xl text-[var(--color-fg-muted)] leading-relaxed"
    >
      HeadlessOS is a desktop for your Linux servers. Files, Docker, processes,
      logs, and firewall — all in one place, all over the SSH access you already
      have.
      <span class="block mt-2 text-[var(--color-fg)] font-medium">
        No agent. No port to open. Nothing installed on the server.
      </span>
    </p>

    <div class="mt-9 flex flex-wrap justify-center gap-3">
      <a href="/docs/getting-started" class="btn btn-primary">
        Try it in 60 seconds
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="https://github.com/abhee235/headlessos"
        target="_blank"
        rel="noopener"
        class="btn btn-secondary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-1-.02-1.96-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.9 10.9 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.74.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        View source on GitHub
      </a>
    </div>

    <!-- Trust strip -->
    <ul
      class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-[var(--color-fg-subtle)]"
    >
      {
        socialProof.map((p) => (
          <li class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            {p}
          </li>
        ))
      }
    </ul>

    <!-- Product preview carousel -->
    <div class="mt-16">
      <HeroCarousel />
    </div>
  </div>
</section>
