---
// Final CTA / Open source banner
---

<section class="relative py-28 border-t border-[var(--color-border)]">
  <div class="mx-auto max-w-5xl px-6">
    <div
      class="relative overflow-hidden rounded-3xl glass-strong p-10 sm:p-14 text-center"
    >
      <!-- Background gradient -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-[rgba(0,212,255,0.08)] via-transparent to-[rgba(124,58,237,0.08)] pointer-events-none"
      >
      </div>
      <div
        class="absolute -top-20 left-1/2 -translate-x-1/2 h-60 w-[500px] bg-[var(--color-brand-500)] opacity-15 blur-3xl pointer-events-none"
      >
      </div>

      <div class="relative">
        <div
          class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[var(--color-brand-500)] to-[var(--color-accent-500)] shadow-lg"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
            <path
              d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-1-.02-1.96-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.9 10.9 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.74.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
            />
          </svg>
        </div>

        <h2 class="mt-6 text-4xl sm:text-5xl font-bold tracking-tight">
          Free. Open source. <span class="gradient-text">Yours.</span>
        </h2>
        <p
          class="mx-auto mt-4 max-w-xl text-lg text-[var(--color-fg-muted)]"
        >
          HeadlessOS is MIT licensed. Star the repo, file an issue, or send a
          pull request — we'd love your help.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href="https://github.com/abhee235/headlessos"
            target="_blank"
            rel="noopener"
            class="btn btn-primary"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8 5.8 21.3l2.4-7.4L2 9.4h7.6L12 2z" />
            </svg>
            Star on GitHub
          </a>
          <a href="/docs/contributing" class="btn btn-secondary">
            Contributing guide
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
